{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "orchestro",
  "version": "0.1.0",
  "identifier": "com.gracious-determined-curie.orchestro",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Orchestro",
        "width": 1360,
        "height": 880,
        "minWidth": 1180,
        "minHeight": 720,
        "backgroundColor": "#000000"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://api.openai.com https://api.anthropic.com https://generativelanguage.googleapis.com https://api.groq.com https://openrouter.ai http://localhost:11434 http://localhost:1420 ws://localhost:1420; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Or1onn/Orchestro/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCNkY0QTY0ODUxNjJGRjUKUldUMUx4YUZaRXB2YXpTOWQxQVBmSGozZi9veWpLbXNhK2JjUG1CQzczQVl0VDFiS1N1aDQrOFcK"
    }
  }
}
